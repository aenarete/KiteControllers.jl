#!/bin/bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_DIR" || exit 1

if [[ "$1" == "--list" ]]; then
	echo "Available log files:"
	find "$REPO_DIR/output" -maxdepth 1 -type f -name "*.arrow" -printf "%f\n" | sort
	exit 0
fi

"$REPO_DIR/bin/run_julia" "examples/batch_plot.jl" "$@"
